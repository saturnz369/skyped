# Copy this file to:
#   $HOME/skyped_host_runtime/env/jetson.env
# or point HOST_RUNTIME_ENV_FILE at a different location.

export HOST_RUNTIME_ROOT="${HOME}/skyped_host_runtime"

# Per-Jetson desktop session values for preview-enabled launches.
# Use the display that is actually active on this Jetson.
# Common examples are :0 and :1.
export DISPLAY=":0"
# export XAUTHORITY="/run/user/1000/gdm/Xauthority"

# Actual Ethernet IP that MK15 should target on this Jetson.
export RTSP_HOST_IP="192.168.144.100"

# Jetson -> PX4 companion serial link.
export SERIAL_DEVICE="/dev/ttyUSB0"
export SERIAL_BAUD="921600"

# Machine-local Python runtime for the bridge/model helpers.
# Set this to the bridge/export venv that exists on this Jetson.
# export PYTHON_BIN="${HOST_RUNTIME_ROOT}/venv/bin/python"

# Optional local runtime locations outside git.
# export HOST_RUNTIME_RUNS_ROOT="${HOST_RUNTIME_ROOT}/runs/profile_640_fp16_archery_target"
# export HOST_RUNTIME_PROFILE_BIN_DIR="${HOST_RUNTIME_ROOT}/bin/profile_640_fp16_archery_target"
