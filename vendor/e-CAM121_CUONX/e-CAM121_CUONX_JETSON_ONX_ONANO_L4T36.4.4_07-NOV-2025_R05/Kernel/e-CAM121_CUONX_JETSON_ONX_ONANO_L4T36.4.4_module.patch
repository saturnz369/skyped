+
+        uint16_t cmd_status = 0;
+        uint8_t retcode = 0, cmd_id = 0;
+	int retry = 1000, err = 0;
+        /* call ISP init command */
+
+	/*lock semaphore*/
+        mutex_lock(&priv->cam_i2c_mutex);
+
+        /* First Txn Payload length = 0 */
+        payload_len = 0;
+
+        mc_data[0] = CMD_SIGNATURE;
