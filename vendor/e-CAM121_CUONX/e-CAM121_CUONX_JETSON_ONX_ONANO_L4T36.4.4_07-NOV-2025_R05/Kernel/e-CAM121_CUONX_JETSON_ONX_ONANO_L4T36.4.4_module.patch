+
+int tegra_custom_s_ctrl (struct v4l2_ctrl *ctrl)
+{
+
+	struct tegra_channel *chan = container_of(ctrl->handler,
+                                struct tegra_channel, ctrl_handler);
+	struct v4l2_subdev *sd = chan->subdev_on_csi;
+	struct tegracam_ctrl_handler *handler = container_of(sd->ctrl_handler,
+                                struct tegracam_ctrl_handler, ctrl_handler);
+	struct tegracam_device *tc_dev = handler->tc_dev;
+	struct device *dev = tc_dev->dev;
+
+	s32 val = ctrl->val;
+	int err = 0;
+	switch (ctrl->id) {
+		case TEGRA_CAMERA_CID_FRAME_SYNC:
+			if ((err = cam_set_frame_sync(tc_dev, val)) < 0) {
+				dev_err(dev,"Error in setting trigger mode\n");
+				return err;
+			}
+			break;
+
+		default:
+			dev_err(dev, "No such control is available\n");
+			return -EINVAL;
+	}
+	return 0;
+}
+
+static const struct v4l2_ctrl_ops channel_ctrl_ops = {
