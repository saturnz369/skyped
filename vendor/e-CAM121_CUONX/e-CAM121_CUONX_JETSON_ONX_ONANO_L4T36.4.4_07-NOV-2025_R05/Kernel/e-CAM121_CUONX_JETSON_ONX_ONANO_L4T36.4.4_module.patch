+static struct i2c_driver cam_i2c_driver = {
+	.driver = {
+		.name = "e-con_cam",
+		.owner = THIS_MODULE,
+		.of_match_table = of_match_ptr(cam_of_match),
+	},
+	.probe = cam_probe,
+	.remove = cam_remove,
+	.id_table = cam_id,
+};
