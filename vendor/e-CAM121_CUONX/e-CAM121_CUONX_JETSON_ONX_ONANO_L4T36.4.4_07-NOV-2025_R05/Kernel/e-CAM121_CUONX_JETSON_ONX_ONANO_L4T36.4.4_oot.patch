+		total_connected_cam++;
+	ret_val = 0;
+
+	err = max96712_read_reg_Dser(0x52, des_channel, 0x000A, &ret_val);
+	if(ret_val != 0)
+		total_connected_cam++;
+	ret_val = 0;
+
+	err = max96712_read_reg_Dser(0x52, des_channel, 0x000B, &ret_val);
