+		total_connected_cam++;
+	ret_val = 0;
+
+	err = max96712_read_reg_Dser(0x52, des_channel, 0x000C, &ret_val);
+	if(ret_val & 0x08)
+		total_connected_cam++;
+	ret_val = 0;
+#endif
+
 	/*set daymode by fault*/
 	dev_info(&client->dev, "%s:  success\n", __func__);
 
 	return err;
 }
 
+#ifdef CONFIG_VIDEO_ECAM
+EXPORT_SYMBOL(total_connected_cam);
+#endif
